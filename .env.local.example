DATABASE_URL=

AUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Opcional: se quiser explicitar a URL canónica do Auth.js sem repetir valor
AUTH_URL=$NEXT_PUBLIC_APP_URL

# Stripe (test ou live)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Intervalo usado no Checkout ao criar org com plano pago: monthly | annual
STRIPE_DEFAULT_BILLING_INTERVAL=monthly

# Price IDs — Starter (uso futuro / upgrades; plano Free na app não abre Checkout)
STRIPE_PRICE_STARTER_MONTHLY=
STRIPE_PRICE_STARTER_ANNUAL=

# Growth (plano growth na BD)
STRIPE_PRICE_GROWTH_MONTHLY=
STRIPE_PRICE_GROWTH_ANNUAL=

# Scale no Stripe ↔ plano scale na BD (subscription_plan.scale)
STRIPE_PRICE_SCALE_MONTHLY=
STRIPE_PRICE_SCALE_ANNUAL=
